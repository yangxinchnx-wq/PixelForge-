{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PixelForge",
  "identifier": "com.pixelforge.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "PixelForge",
        "width": 1390,
        "height": 850,
        "minWidth": 1390,
        "minHeight": 850,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "PixelForge",
    "category": "GraphicsAndDesign",
    "shortDescription": "PixelForge - WebGPU real-time graphics authoring",
    "longDescription": "PixelForge is a WebGPU-powered real-time graphics authoring and rendering tool built with Vue 3, TypeScript, and Tauri.",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
